{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "lib": ["ES2020", "DOM", "DOM.Iterable", "WebWorker"],
    "strict": true,
    "types": ["chrome"],
    "esModuleInterop": true,
    "moduleResolution": "bundler",
    "outDir": "./dist",
    "rootDir": "./src",
    "sourceMap": true,
    "declaration": false,
    "resolveJsonModule": true,
    "skipLibCheck": true
  },
  "include": ["src/**/*"],
  "exclude": [
    "node_modules",
    "dist",
    // Node-only offline tooling (run via `tsx`, never bundled into the
    // extension). These use Node APIs (fs/path/process/__dirname) that are not
    // part of the extension's chrome-typed runtime, so they are excluded from
    // the webpack/ts-loader program. The solver's runtime output
    // (src/core/ranges/headsup-solved.ts) is plain data and IS included.
    "src/solver/preflop/run-solve.ts",
    "src/solver/preflop/build-equity.ts",
    "src/solver/preflop/equity-matrix.ts",
    "src/solver/bench.ts"
  ]
}
